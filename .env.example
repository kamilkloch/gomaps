# Server-side key for Places API requests (recommended: unrestricted or IP-restricted)
GOOGLE_PLACES_API_KEY=your_server_places_api_key_here

# Backward-compatible fallback used by server when GOOGLE_PLACES_API_KEY is unset
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Browser key for Maps JavaScript API (can be HTTP-referrer restricted)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
